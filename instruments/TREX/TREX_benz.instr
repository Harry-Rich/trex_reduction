 filename = "source_monitor_xy.dat", geometry = "NULL",
 nowritefile = 0, nexus_bins = 0,
 username1 = "NULL", username2 = "NULL",
 username3 = "NULL")
AT (-0.002, 0, 1.8953) ABSOLUTE

COMPONENT source_monitor_div = Monitor_nD(
 user1 = "", user2 = "",
 user3 = "", xwidth = 0.09,
