 max = 1e40, restore_neutron = 1,
 radius = 0, options = "hdiv limits [-2.5:2.5] bins = 100, vdiv limits [-2.5:2.5] bins = 100",
 filename = "source_monitor_div.dat", geometry = "NULL",
 nowritefile = 0, nexus_bins = 0,
 username1 = "NULL", username2 = "NULL",
 username3 = "NULL")
AT (-0.002, 0, 1.8954) ABSOLUTE

COMPONENT guide_0 = Guide_anyshape_r(
