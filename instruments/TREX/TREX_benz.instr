AT (0, 0, 0) ABSOLUTE

COMPONENT guide_10 = Guide_anyshape_r(
 xwidth = 0, yheight = 0,
 zdepth = 0, center = 0,
 transmit = 0, R0 = 0.99,
 Qc = 0.0219, alpha = 0,
 m = 0, W = 0,
 geometry = "./OFF_files/try10.off")
WHEN (( bender == 0 ))
AT (0, 0, 0) ABSOLUTE

COMPONENT bender = Pol_bender(
 xwidth = 0.06384, yheight = 0.046,
 length = 0.05, radius = 7.2,
 G = 9.8, nslit = 425,
 d = 1e-6, debug = 0,
 endFlat = 0, rTopUpPar = { 0.99 , 0.0219 , 3.02 , 4.0 , 0.003 },
 rTopDownPar = { 0.99 , 0.0219 , 3.02 , 4.0 , 0.003 }, rBotUpPar = { 0.99 , 0.0219 , 6.07 , 2.0 , 0.003 },
 rBotDownPar = { 0.99 , 0.0219 , 6.07 , 2.0 , 0.003 }, rLeftUpPar = { 0.99 , 0.0219 , 6.07 , 2.0 , 0.003 },
 rLeftDownPar = { 0.99 , 0.0219 , 6.07 , 2.0 , 0.003 }, rRightUpPar = { 0.99 , 0.0219 , 6.07 , 2.0 , 0.003 },
 rRightDownPar = { 0.99 , 0.0219 , 6.07 , 2.0 , 0.003 }, rTopUpData = "",
 rTopDownData = "", rBotUpData = "",
 rBotDownData = "", rLeftUpData = "",
 rLeftDownData = "", rRightUpData = "",
